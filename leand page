}

.gradient-bg{
position:fixed;
width:100%;
height:100%;
z-index:-1;
background:
radial-gradient(circle at 20% 20%, rgba(37,99,255,.25), transparent 30%),
radial-gradient(circle at 80% 30%, rgba(255,184,0,.15), transparent 25%),
radial-gradient(circle at 50% 80%, rgba(37,99,255,.15), transparent 30%),
#050816;
}

.container{
width:90%;
max-width:1200px;
margin:auto;
}

.hero{
padding:100px 0;
}

.hero-content{
display:grid;
grid-template-columns:1fr 500px;
gap:60px;
align-items:center;
}

.badge{
display:inline-block;
padding:12px 20px;
border-radius:999px;
background:rgba(255,184,0,.15);
border:1px solid rgba(255,184,0,.4);
color:#ffb800;
font-weight:700;
margin-bottom:25px;
}

h1{
font-size:68px;
line-height:1;
font-weight:900;
margin-bottom:25px;
}

.highlight{
color:#ffb800;
}

.subtitle{
font-size:22px;
line-height:1.7;
color:#b8c3e4;
margin-bottom:35px;
}

.btn{
display:inline-block;
padding:20px 35px;
border-radius:16px;
background:linear-gradient(135deg,#ffb800,#ff8c00);
color:#000;
font-weight:900;
text-decoration:none;
font-size:18px;
box-shadow:0 0 40px rgba(255,184,0,.35);
transition:.3s;
}

.btn:hover{
transform:translateY(-5px);
box-shadow:0 0 60px rgba(255,184,0,.7);
}

.hero-image{
position:relative;
}

.hero-image img{
width:100%;
border-radius:25px;
box-shadow:
0 0 80px rgba(37,99,255,.4),
0 0 120px rgba(255,184,0,.15);
}

section{
padding:100px 0;
}

.section-title{
text-align:center;
max-width:900px;
margin:auto auto 60px;
}

.section-title h2{
font-size:52px;
margin-bottom:20px;
}

.section-title p{
color:#b8c3e4;
font-size:20px;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:25px;
}

.card{
background:rgba(255,255,255,.04);
backdrop-filter:blur(20px);
padding:35px;
border-radius:24px;
border:1px solid rgba(255,255,255,.08);
transition:.4s;
}

.card:hover{
transform:translateY(-10px);
border-color:#ffb800;
}

.card h3{
margin-bottom:15px;
color:#ffb800;
}

.card p{
color:#b8c3e4;
line-height:1.7;
}

.flow{
display:flex;
justify-content:center;
align-items:center;
flex-wrap:wrap;
gap:20px;
}

.step{
padding:20px 30px;
background:#111827;
border-radius:20px;
font-weight:800;
}

.arrow{
font-size:35px;
color:#ffb800;
}

.offer{
max-width:850px;
margin:auto;
text-align:center;
background:linear-gradient(135deg,#0d1737,#111827);
padding:60px;
border-radius:30px;
border:1px solid rgba(255,184,0,.3);
}

.old{
font-size:28px;
text-decoration:line-through;
color:#8091bf;
}

.price{
font-size:90px;
font-weight:900;
color:#ffb800;
margin:10px 0;
}

.list{
list-style:none;
margin:35px 0;
}

.list li{
margin:12px 0;
font-size:20px;
}

.faq{
max-width:900px;
margin:auto;
}

details{
background:#111827;
padding:20px;
border-radius:16px;
margin-bottom:15px;
}

summary{
cursor:pointer;
font-weight:700;
color:#ffb800;
}

details p{
margin-top:15px;
color:#b8c3e4;
}

.footer-cta{
text-align:center;
padding:120px 20px;
}

.footer-cta h2{
font-size:60px;
margin-bottom:25px;
}

.sticky{
position:fixed;
bottom:20px;
left:50%;
transform:translateX(-50%);
background:#0d1737;
padding:15px 20px;
border-radius:18px;
display:flex;
gap:15px;
align-items:center;
z-index:999;
border:1px solid rgba(255,184,0,.3);
box-shadow:0 0 40px rgba(0,0,0,.4);
}

.sticky a{
padding:12px 18px;
border-radius:10px;
background:#ffb800;
color:#000;
text-decoration:none;
font-weight:800;
}

@media(max-width:1000px){

.hero-content{
grid-template-columns:1fr;
text-align:center;
}

h1{
font-size:48px;
}

.hero-image{
max-width:450px;
margin:auto;
}

.section-title h2{
font-size:40px;
}

.footer-cta h2{
font-size:42px;
}

.price{
font-size:60px;
}

}

</style>
</head>
